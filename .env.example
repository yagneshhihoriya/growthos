# ── Local dev (Docker) ─────────────────────────────────────────────
# Start: docker compose up -d
# Postgres: localhost:5432  Redis: localhost:6379
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/growthos"
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Google OAuth (optional but recommended)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Meta / Facebook OAuth (optional but recommended)
META_CLIENT_ID=""
META_CLIENT_SECRET=""

# AWS S3
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="growthos-images"
AWS_CLOUDFRONT_URL=""

# Remove.bg (primary BG removal)
REMOVEBG_API_KEY=""

# Clipdrop (fallback BG removal when Remove.bg quota exceeded)
CLIPDROP_API_KEY=""

# Cloudinary (optional; falls back to Sharp-only enhancement)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Stability AI (legacy)
STABILITY_API_KEY=""

# Google Gemini — Photo Studio image generate/edit (required for /api/images/generate)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=""
# Optional override; default is gemini-2.5-flash-image (Nano Banana)
# GEMINI_IMAGE_MODEL="gemini-3.1-flash-image-preview"

# AES-256-GCM encryption key (64 hex chars = 32 bytes)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# Pusher (real-time batch progress)
PUSHER_APP_ID=""
PUSHER_APP_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# Email (Resend API — optional, prints to console in dev if not set)
RESEND_API_KEY=""
EMAIL_FROM="GrowthOS <noreply@growthos.in>"

# Vercel Cron + local BullMQ worker (`npm run worker:social`) — same secret as Authorization: Bearer
CRON_SECRET=""
